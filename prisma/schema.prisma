generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model conversations {
  id              String   @id(map: "conversations_pk") @db.Uuid
  session_id      String   @db.Uuid
  started_at      DateTime @db.Timestamp(6)
  last_message_at DateTime @db.Timestamp(6)
  message_count   Int      @default(0)
  token_count     Int      @default(0)
  comment         String?

  @@index([session_id, last_message_at(sort: Desc)], map: "idx_conversations_session")
}

model hr_sessions {
  id             String    @id(map: "hr_sessions_pk") @db.Uuid
  cookie_token   String    @unique(map: "hr_sessions_unique")
  ip_address     String
  user_agent     String?
  company_hint   String?
  is_interesting Boolean?
  first_seen_at  DateTime? @db.Timestamp(6)
  last_seen_at   DateTime? @db.Timestamp(6)

  @@index([cookie_token], map: "idx_hr_sessions_cookie")
  @@index([last_seen_at(sort: Desc)], map: "idx_hr_sessions_last_seen")
}

model messages {
  id              String   @id(map: "messages_pk") @db.Uuid
  conversation_id String   @db.Uuid
  role            String
  content         String
  created_at      DateTime @db.Timestamp(6)
  used_token      Int      @default(0)

  @@index([conversation_id, created_at(sort: Desc)], map: "idx_messages_conversation_date")
}

model my_cv {
  id         String    @id(map: "my_cv_pk") @db.Uuid
  name       String
  cv_content Json      @default("{}")
  created_at DateTime? @db.Timestamp(6)
  created_by String?
  updated_at DateTime? @db.Timestamp(6)
  updated_by String?
  is_active  Boolean?  @default(true)
}

model users {
  id         String    @id(map: "users_pk") @db.Uuid
  nickname   String?
  password   String
  email      String    @unique(map: "users_unique")
  fullname   String?
  created_at DateTime? @db.Timestamp(6)
  created_by String?
  updated_at DateTime? @db.Timestamp(6)
  updated_by String?
}

model projects {
  id          String    @id(map: "projects_pk") @db.Uuid
  repo_name   String    @db.VarChar(255)
  description String
  tech_stack  String[]
  highlights  String
  markdown    String
  github_url  String?   @db.VarChar(255)
  live_url    String?   @db.VarChar(255)
  sort_order  Int?      @default(0)
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  created_by  String?
  updated_by  String?
  is_active   Boolean?  @default(true)

  @@index([sort_order(sort: Desc)], map: "idx_projects_feature_order")
}

enum message_role {
  hr
  bot
}
